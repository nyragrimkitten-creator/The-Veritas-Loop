# ====================================================================
# Aion Cognitive Architecture - Core .gitignore
# ====================================================================

# --- Operating System Junk ---
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Linux
*~

# --- IDEs and Text Editors ---
# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
!.vscode/tasks.json

# JetBrains (WebStorm, IntelliJ, PyCharm, etc.)
.idea/

# Sublime Text / Vim
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# --- Security & Local Environments ---
# Crucial if you ever write local testing scripts using LLM API keys
.env
.env.local
.env.*.local
*.pem
*.key

# --- Logs & Diagnostics ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
